# API Configuration
API_KEY=your-openai-api-key-here

# Database Configuration
DATABASE_URL=sqlite:///./silogia.db

# CORS Configuration
# Add your frontend URLs here (comma-separated)
# Development example:
# CORS_ORIGINS=http://localhost:3000,http://localhost:9002
# Production example:
# CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:9002

# API Documentation Security
# Set to 'true' to enable API documentation endpoints (/docs, /redoc, /openapi.json)
# IMPORTANT: Keep this 'false' in production for security
DOCS_ENABLED=false

# Credentials for accessing API documentation (only if DOCS_ENABLED=true)
# Change these values to secure your documentation
DOCS_USERNAME=admin
DOCS_PASSWORD=your-secure-password-here

# Server Configuration (for production)
# HOST=0.0.0.0
# PORT=8000
